{
  "name": "myphonedoctor",
  "version": "1.0.0",
  "description": "Professional Android Flash Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.myphonedoctor.flashsuite",
    "productName": "MyPhoneDoctor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "adbkit": "^2.11.1"
  }
}
